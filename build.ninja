# Ninja build file generated by script
rule generate_kde
  command=/home/runner/work/investing/investing/scripts/simulate.py '$INDEX' --hold $HOLD --years $YEARS $ADJUST_CURRENCY $ADJUST_INFLATION
  description=Generating KDE for $in -> $out

rule compute_correlation
  command=/home/runner/work/investing/investing/scripts/compute-correlation.py $INDICES > $out
  description=Producing correlation data in $out

build facts/indexes-correlation.csv: compute_correlation facts/indexes/euro-stoxx-50-index.csv facts/indexes/euro-stoxx-index-eur.csv facts/indexes/null.csv facts/indexes/s&p-500-index.csv facts/indexes/s&p-global-1200-index.csv facts/indexes/s&p-small-cap-600-growth-index.csv facts/indexes/stoxx-europe-600-index.csv facts/indexes/stoxx-global-1800-index-usd.csv
  INDICES= "euro-stoxx-50-index" "euro-stoxx-index-eur" "null" "s&p-500-index" "s&p-global-1200-index" "s&p-small-cap-600-growth-index" "stoxx-europe-600-index" "stoxx-global-1800-index-usd"

build simulations/euro-stoxx-50-index/hold-1.0/years-10/adjust-currency/adjust-inflation/kde.json: generate_kde facts/indexes/euro-stoxx-50-index.csv
  YEARS = 10
  HOLD = 1.0
  INDEX = euro-stoxx-50-index
  ADJUST_CURRENCY = 
  ADJUST_INFLATION = 
